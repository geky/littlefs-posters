# limit cache sizes to physical read/prog size
$(foreach sim, $(BENCH_SIMS),$\
	$(eval P26_T_$(U_$(sim))_CACHE_SIZES := $(shell python -c 'print($\
			",".join(str(n) for n in [$(P26_T_CACHE_SIZES)] $\
				if n >= max($\
					$($(U_$(sim))_READ_SIZE),$\
					$($(U_$(sim))_PROG_SIZE))))')))

# p26 cache size bench subrule
#
# note the *3 to keep things fair with how littlefs uses buffers, this
# also assumes a minimum page size of 256
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - disk size
# $6 - file size
# $7 - cache size
#
define BENCH_P26_T_CS_CS_RULE
$1: $(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(or $5,$(DISK_SIZE)) \
		-DSIZE=$(or $6,$(P26_T_SIZE)) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIMTIME=$(P26_T_SIMTIME) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$($(U_$4)_$(U_$3)_BLOCK_SIZE) \
		-DPCACHE_SIZE=$7 \
		-DRCACHE_SIZE=$7 \
		-DFILE_CACHE_SIZE=$7 \
		-DCACHE_SIZE=$7 \
		-DPAGECACHE_COUNT=$$(shell python -c '$\
			print(max(2, __import__("math").ceil($\
				($7*3) / max($\
					256,$\
					$($(U_$4)_READ_SIZE),$\
					$($(U_$4)_PROG_SIZE)))))') \
		-o$$@)
endef

# p26 cache size bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - disk size
# $6 - file size
# $7 - cache sizes
#
define BENCH_P26_T_CS_RULE
$(foreach cs, $(subst $(,), ,$(or $7,$(P26_T_$(U_$4)_CACHE_SIZES))), \
	$(eval $(call BENCH_P26_T_CS_CS_RULE,$\
		$(1:.csv=.cs_$(cs).csv),$\
		$2,$\
		$3,$\
		$4,$\
		$5,$\
		$6,$\
		$(cs))))

$1: $(foreach cs, $(subst $(,), ,$(or $7,$(P26_T_$(U_$4)_CACHE_SIZES))), \
		$(patsubst %.csv,%.cs_$(cs).csv,$1))
	$$(strip ./scripts/csv.py $$^ \
		-fbench_readed \
		-fbench_proged \
		-fbench_erased \
		-fbench_creaded \
		-fbench_cproged \
		-fbench_cerased \
		-o$$@)
endef

# p26 cache size bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_CS_RULE,$\
				$(RESULTSDIR)/bench_p26_cs_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))



