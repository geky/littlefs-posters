		CACHE_SIZE,$\
		$(P26_T_CACHE_SIZES),$\
		usage,$\
		--xlabel="cache size" --y2 --yunits=B))

$(eval $(call PLOT_P26_CS_RULE,$\
		$(PLOTSDIR)/bench_p26_cs_ram_%.svg,$\
		$(foreach fs, $(BENCH_FSS),$\
			$(foreach sim, $(BENCH_SIMS),$\
