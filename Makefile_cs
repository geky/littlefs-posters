# use our bench rules
BENCH_RULES ?= \
	bench-p26-cs
# use our plot rules
PLOT_RULES ?= \
	plot-p26-cs \
	plot-p26-cs-usage \
	plot-p26-cs-ram

# default Makefile does most of the work
