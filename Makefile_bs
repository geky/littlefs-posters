# range of erase sizes to test for throughput testing
P26_T_BLOCK_SIZES ?= 4096,8192,16384,32768,65536,131072
P26_T_BLOCK_SIZES_1M ?= 4096,8192,16384,32768,65536,131072,$\
		262144,524288,1048576

