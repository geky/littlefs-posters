# p26 block size bench rule
#
# $1 - target
# $2 - bench case
# $3 - fs type/version
# $4 - sim type
# $5 - disk size
# $6 - file size
# $7 - block sizes
#
define BENCH_P26_T_BS_RULE
$1: $$(BENCH_$(U_$3)_RUNNER)
	$$(strip ./scripts/bench.py -R$$< -B $2 \
		$(BENCHFLAGS) \
		-DDISK_SIZE=$(or $5,$(DISK_SIZE)) \
		-DSIZE=$(or $6,$(P26_T_SIZE)) \
		-DCHUNK=$(P26_T_CHUNK) \
		-DSIMTIME=$(P26_T_SIMTIME) \
		-DFS=$(N_$3) \
		-DREAD_SIZE=$$($(U_$4)_READ_SIZE) \
		-DPROG_SIZE=$$($(U_$4)_PROG_SIZE) \
		-DERASE_SIZE=$$($(U_$4)_ERASE_SIZE) \
		-DREAD_TIME=$$($(U_$4)_READ_TIME) \
		-DPROG_TIME=$$($(U_$4)_PROG_TIME) \
		-DERASE_TIME=$$($(U_$4)_ERASE_TIME) \
		-DBLOCK_SIZE=$(or $7,$(P26_T_BLOCK_SIZES)) \
		-o$$@)
endef

# p26 block size bench rules
$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_BS_RULE,$\
				$(RESULTSDIR)/bench_p26_bs_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim)))))

$(foreach fs, $(BENCH_FSS),$\
	$(foreach sim, $(BENCH_SIMS),$\
		$(eval $(call BENCH_P26_T_BS_RULE,$\
				$(RESULTSDIR)/bench_p26_bs_1M_%.$(fs).$(sim).csv,$\
				bench_p26_wt_$$*,$\
				$(fs),$\
				$(sim),$\
				$(DISK_SIZE_1M),$\
				$(P26_T_SIZE_1M),$\
				$(P26_T_BLOCK_SIZES_1M)))))



